# Copy to .env.local and fill in values. Do NOT commit .env.local.

# Tempo RPC (optional)
RPC_URL=https://rpc.moderato.tempo.xyz

# Required: the token you want to use as fee token
USER_TOKEN=0x0000000000000000000000000000000000000000

# Optional: validator token (defaults to AlphaUSD on Moderato)
VALIDATOR_TOKEN=0x20c0000000000000000000000000000000000001

# Option A (recommended): simulate-only mode (no private key)
ACCOUNT_ADDRESS=0x0000000000000000000000000000000000000000

# Option B: can-send mode (ONLY for local testing; never share keys)
# PRIVATE_KEY can be 64-hex with or without 0x prefix
# PRIVATE_KEY=0x........................................................

# Set to 1 to broadcast the transaction when simulate succeeds (requires PRIVATE_KEY)
# SEND_TX=1
VITE_WALLETCONNECT_PROJECT_ID=

# If deploying under a subpath (e.g. GitHub Pages: /Tempo-Testnet/)
# VITE_BASE_PATH=/Tempo-Testnet/

# Tempo RPC (official testnet)
VITE_TEMPO_RPC_URL=https://rpc.moderato.tempo.xyz

# Optional overrides (defaults are predeployed on Tempo testnet)
VITE_CONTRACT_DEX=0xdec0000000000000000000000000000000000000
VITE_CONTRACT_TOKEN_FACTORY=0x20fc000000000000000000000000000000000000
VITE_CONTRACT_FEE_MANAGER=0xfeec000000000000000000000000000000000000
VITE_CONTRACT_TIP403_REGISTRY=0x403c000000000000000000000000000000000000
